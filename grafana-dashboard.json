{
  "id": null,
  "uid": "cgmsharp",
  "title": "CGM Glucose",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Glucose (mmol/L)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 12 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"cgmsharp\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"glucose\" and r._field == \"value\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "mmol/L",
          "min": 0,
          "max": 21,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "pointSize": 4,
            "showPoints": "always",
            "axisGridShow": false,
            "thresholdsStyle": {
              "mode": "line+area"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "dark-red" },
              { "value": 3.0, "color": "red" },
              { "value": 3.9, "color": "green" },
              { "value": 10.0, "color": "orange" },
              { "value": 13.9, "color": "red" }
            ]
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Below Range (<3.9)",
      "description": "Target: <4%",
      "gridPos": { "x": 0, "y": 12, "w": 6, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "targets": [
        {
          "refId": "total",
          "query": "from(bucket: \"cgmsharp\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"glucose\" and r._field == \"value\") |> group() |> count() |> map(fn: (r) => ({_value: r._value, _field: \"total\", _time: now()}))",
          "hide": true
        },
        {
          "refId": "count",
          "query": "from(bucket: \"cgmsharp\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"glucose\" and r._field == \"value\") |> filter(fn: (r) => r._value < 3.9) |> group() |> count() |> map(fn: (r) => ({_value: r._value, _field: \"count\", _time: now()}))",
          "hide": true
        }
      ],
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "mode": "binary",
            "binary": {
              "left": "count",
              "operator": "/",
              "right": "total"
            },
            "alias": "percent",
            "replaceFields": true
          }
        },
        {
          "id": "calculateField",
          "options": {
            "mode": "binary",
            "binary": {
              "left": "percent",
              "operator": "*",
              "right": "100"
            },
            "alias": "result",
            "replaceFields": true
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 4, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "textMode": "value"
      }
    },
    {
      "type": "stat",
