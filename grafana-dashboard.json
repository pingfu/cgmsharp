    {
      "type": "timeseries",
      "title": "Daily Overlay (last 7 days)",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 12 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "targets": [
        {
          "refId": "A",
          "query": "import \"date\"\n\nyesterday = int(v: date.truncate(t: now(), unit: 1d)) - 86400000000000\n\nfrom(bucket: \"cgmsharp\")\n  |> range(start: -7d)\n  |> filter(fn: (r) => r._measurement == \"glucose\" and r._field == \"value\")\n  |> map(fn: (r) => ({\n    _value: r._value,\n    _field: (if date.monthDay(t: r._time) < 10 then \"0\" else \"\") + string(v: date.monthDay(t: r._time)) + \"/\" + (if int(v: date.month(t: r._time)) < 10 then \"0\" else \"\") + string(v: int(v: date.month(t: r._time))),\n    _time: time(v: yesterday + (int(v: r._time) - int(v: date.truncate(t: r._time, unit: 1d))))\n  }))\n  |> group(columns: [\"_field\"])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 21,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "pointSize": 3,
            "showPoints": "always",
            "axisGridShow": false,
            "thresholdsStyle": {
              "mode": "line+area"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "dark-red" },
              { "value": 3.0, "color": "red" },
              { "value": 3.9, "color": "green" },
              { "value": 10.0, "color": "orange" },
              { "value": 13.9, "color": "red" }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right"
        }
      }
