{
  "id": null,
  "uid": "cgmsharp",
  "title": "CGM Glucose",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Glucose (mmol/L)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 12 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"cgmsharp\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"glucose\" and r._field == \"value\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "mmol/L",
          "min": 0,
          "max": 21,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "pointSize": 4,
            "showPoints": "always",
            "thresholdsStyle": {
              "mode": "area"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 3.9, "color": "green" },
              { "value": 10.0, "color": "orange" },
              { "value": 13.9, "color": "red" }
            ]
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    }
  ]
}
